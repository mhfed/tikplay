{
  "name": "craw-music",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack && cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static",
    "start": "node .next/standalone/server.js",
    "lint": "biome check",
    "format": "biome format --write",
    "test:e2e": "playwright test",
    "test:personalization": "tsx --test scripts/personalization-ranking.test.ts scripts/wave4-personalization-contract.test.ts",
    "retention:listening": "tsx scripts/purge-listening-events.ts",
    "privacy:purge": "tsx scripts/purge-deleted-users.ts",
    "test:migration": "tsx --test scripts/legacy-json-core.test.ts scripts/legacy-json-contract.test.ts",
    "test:wave3": "tsx --test scripts/wave3-api-contract.test.ts",
    "test:guest-import": "tsx --test scripts/guest-import.test.ts scripts/guest-import-contract.test.ts",
    "test:privacy": "tsx --test scripts/privacy-contract.test.ts",
    "migrate:legacy:dry-run": "tsx scripts/migrate-legacy-json.ts",
    "migrate:legacy:import": "tsx scripts/migrate-legacy-json.ts --import",
    "migrate:legacy:rollback": "tsx scripts/migrate-legacy-json.ts --rollback",
    "youtube:cookies": "bash scripts/set-youtube-cookies.sh",
    "test:wave5:test-hooks": "tsx --test scripts/test-hooks-production-guard.test.ts",
    "test:wave5:security": "NODE_OPTIONS='--require ./scripts/register-server-only-stub.cjs' tsx --test scripts/security-regression.test.ts",
    "test:wave5:isolation": "NODE_OPTIONS='--require ./scripts/register-server-only-stub.cjs' tsx --test scripts/two-user-isolation.test.ts",
    "test:wave5:migration": "tsx --test scripts/migration-rehearsal.test.ts",
    "test:wave5": "npm run test:wave5:test-hooks && npm run test:wave5:security && npm run test:wave5:isolation && npm run test:wave5:migration",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-auth": "1.6.24",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.18.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^20.19.43",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "7.0.2"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.10"
  }
}
